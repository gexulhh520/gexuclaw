# Application
APP_NAME=GexuLaw Agent
APP_ENV=development
DEBUG=True

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gexuclaw
CHECKPOINT_DATABASE_URL=postgresql://user:password@localhost:5432/gexuclaw

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# JWT
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Maintenance
MAINTENANCE_CLEANUP_ENABLED=False
MAINTENANCE_CLEANUP_HOUR=3
MAINTENANCE_CLEANUP_MINUTE=30
EXECUTION_STEPS_RETENTION_DAYS=30
EXECUTION_STEPS_CLEANUP_ENABLED=False
CHECKPOINT_RETENTION_DAYS=30
CHECKPOINT_KEEP_PER_THREAD=50
